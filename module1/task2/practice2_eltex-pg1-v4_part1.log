  7z x etc_backup.tar.7z -o/root/etc_backup_7zip_temp
  tar -xf /root/etc_backup_7zip_temp/etc_backup.tar -C /root/etc_backup_7zip
  rm -rf /root/etc_backup_7zip_temp

  diff /root/etc_backup_gzip/etc_backup/motd /root/etc_backup_7zip/etc_backup/motd
