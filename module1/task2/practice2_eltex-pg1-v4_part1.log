1: Создайте на сервере для 1 практики ключ ssh при помощи программы ssh-keygen

  ssh-keygen -t rsa -b 409

  total 24
  drwx------  2 eltex-pg1-v4 eltex-pg1-v4 4096 Mar 17 15:51 .
  drwxr-xr-x 18 eltex-pg1-v4 eltex-pg1-v4 4096 Mar 17 15:53 ..
  -rw-------  1 eltex-pg1-v4 eltex-pg1-v4 3401 Mar 17 15:51 id_rsa
  -rw-r--r--  1 eltex-pg1-v4 eltex-pg1-v4  756 Mar 17 15:51 id_rsa.pub
  -rw-------  1 eltex-pg1-v4 eltex-pg1-v4  978 Mar 17 15:31 known_hosts
  -rw-r--r--  1 eltex-pg1-v4 eltex-pg1-v4  142 Mar 12 19:21 known_hosts.old
