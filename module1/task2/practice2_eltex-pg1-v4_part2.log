4: В файле /etc/passwd найдите всех пользователей в системе, у которых установлен shell
   /usr/sbin/nologin и выведите их в виде списка: «UID, username, список его групп»,
   отсортированный в обратном порядке по UID, cписок групп используйте из файла /etc/group

  awk -F: '$7 ~ /nologin$/ {print $1":"$3}' /etc/passwd | while IFS=: read user uid; do
  > groups=$(grep -E ":.*$user" /etc/group | cut -d: -f1 | tr '\n' ',' | sed 's/,$//')
  > echo "$uid, $user, [$groups]"
  > done | sort -rn
  
  65534, nobody, []
  1003, user3, [users,developers]
  998, systemd-network, []
  997, systemd-timesync, []
  992, systemd-resolve, []
  991, polkitd, []
  989, fwupd-refresh, []
  109, sshd, []
  108, usbmux, []
  107, landscape, []
  105, tcpdump, []
  104, uuidd, []
  103, syslog, [adm]
  101, messagebus, []
  42, _apt, []
  39, irc, []
  38, list, []
  34, backup, []
  33, www-data, []
  13, proxy, []
  10, uucp, []
  9, news, []
  8, mail, []
  7, lp, []
  6, man, []
  5, games, []
  3, sys, [adm]
  2, bin, []
  1, daemon, []

  -F (field separator - :)
  $7 седьмое поле это shell
  выводим первое и третье поле username uid разделенные :
  в цикле для каждой строки раскладываем на user и uid (IFS - Internal Field Separator)
  в group ищем группы содержащие пользователя форматируем и записываем в groups
  выводим отформатированную строку и сортируем по uid
